+# ----------------------------------------------------------------------------
+# Foothold-targeting rewards (Stage-3 Unitree-Go2-Footholds task)
+# ----------------------------------------------------------------------------
+
+def foothold_landing(
+    env: "ManagerBasedRLEnv",
+    sensor_cfg: SceneEntityCfg,
+    asset_cfg: SceneEntityCfg,
+    tolerance: float = 0.10,
+    sigma: float = 0.05,
+    contact_threshold: float = 5.0,
+) -> torch.Tensor:
+    """Sparse Gaussian reward when ANY foot lands within `tolerance` of an
+    unclaimed foothold (permutation-invariant). On contact, the foothold is
+    claimed (state mutated) so subsequent steps see one fewer.
+
+    Implementation note: this term ALSO drives `foothold_state.update_claims`,
+    so it MUST run first in the RewardsCfg ordering — other foothold rewards
+    depend on the just-claimed flag being current.
+    """
+    from unitree_rl_lab.tasks.locomotion.mdp.foothold_state import update_claims
+
+    update_claims(env, sensor_cfg, asset_cfg, tolerance=tolerance, contact_threshold=contact_threshold)
+
+    # Reward = exp(-d^2/sigma^2) summed over stones just claimed in this step
+    if not env._foothold_just_claimed.any():
+        return torch.zeros(env.num_envs, device=env.device)
+
+    # Recompute the distance on the just-claimed stones — we know they were
+    # claimed this step, so distance < tolerance. Use a constant near-1 reward
+    # for the claim event (Gaussian with d≈0 ≈ 1).
+    return env._foothold_just_claimed.float().sum(dim=-1)  # (E,)
+
+
+def foothold_progress(
+    env: "ManagerBasedRLEnv",
+    asset_cfg: SceneEntityCfg,
+    contact_sensor_cfg: SceneEntityCfg,
+) -> torch.Tensor:
+    """Dense reward: for each SWING-PHASE foot, reward its xy velocity component
+    pointing toward its nearest unclaimed foothold.
+
+    Swing phase = currently NOT in contact (last-step contact flag false).
+    Provides a smooth gradient guiding feet toward stones.
+    """
+    asset = env.scene[asset_cfg.name]
+    foot_pos_w = asset.data.body_pos_w[:, asset_cfg.body_ids, :2]        # (E, F, 2)
+    foot_vel_w = asset.data.body_lin_vel_w[:, asset_cfg.body_ids, :2]    # (E, F, 2)
+
+    foothold_xy = env._foothold_positions                                  # (E, S, 2)
+    invalid = env._foothold_claimed | (~env._foothold_active)               # (E, S)
+
+    # nearest unclaimed per foot
+    diff = foot_pos_w.unsqueeze(2) - foothold_xy.unsqueeze(1)               # (E, F, S, 2)
+    dist = torch.linalg.vector_norm(diff, dim=-1)                           # (E, F, S)
+    dist = torch.where(invalid.unsqueeze(1), torch.full_like(dist, float("inf")), dist)
+    min_dist, nearest_idx = dist.min(dim=-1)                                # (E, F)
+
+    # If no unclaimed stones, return zero
+    valid_mask = (min_dist < float("inf"))                                  # (E, F)
+
+    # Direction from foot to nearest stone
+    e_idx = torch.arange(env.num_envs, device=env.device).unsqueeze(1).expand(-1, foot_pos_w.shape[1])
+    f_idx = torch.arange(foot_pos_w.shape[1], device=env.device).unsqueeze(0).expand(env.num_envs, -1)
+    nearest_pos = foothold_xy[e_idx, nearest_idx]                           # (E, F, 2)
+    direction = nearest_pos - foot_pos_w                                    # (E, F, 2)
+    direction = direction / (direction.norm(dim=-1, keepdim=True) + 1e-6)
+
+    # velocity component in direction of nearest stone
+    progress = (foot_vel_w * direction).sum(dim=-1)                         # (E, F)
+
+    # Mask: only swing-phase feet (last-step contact = False), and only valid
+    swing_mask = (~env._foothold_was_contact) & valid_mask                  # (E, F)
+    progress = progress * swing_mask.float()
+
+    return progress.sum(dim=-1)  # (E,)
+
+
+def off_foothold_landing(
+    env: "ManagerBasedRLEnv",
+    sensor_cfg: SceneEntityCfg,
+    asset_cfg: SceneEntityCfg,
+    tolerance: float = 0.15,
+    contact_threshold: float = 5.0,
+) -> torch.Tensor:
+    """Smooth penalty (non-positive) for swing→stance LANDING EVENTS that
+    land far from any foothold. Fires only on the per-step transition
+    (foot was in swing last step, is in stance now), NOT continuously on
+    every stance step.
+
+    Penalty is graded: `−max(0, dist_to_nearest − tolerance)` per landing
+    event. Smooth gradient avoids the binary-threshold pathology that broke
+    the v1 run (continuous-contact penalty was overwhelming all positive
+    rewards because no quadruped pose can place all 4 feet on 0.30m-spaced
+    stones simultaneously).
+
+    Reads `env._foothold_just_landed` published by `update_claims`, so this
+    MUST run AFTER `foothold_landing` in RewardsCfg ordering.
+    """
+    asset = env.scene[asset_cfg.name]
+    if not hasattr(env, "_foothold_just_landed"):
+        return torch.zeros(env.num_envs, device=env.device)
+    just_landed = env._foothold_just_landed                                  # (E, F)
+    if not just_landed.any():
+        return torch.zeros(env.num_envs, device=env.device)
+
+    foot_pos_w = asset.data.body_pos_w[:, asset_cfg.body_ids, :2]            # (E, F, 2)
+    foothold_xy = env._foothold_positions                                    # (E, S, 2)
+    diff = foot_pos_w.unsqueeze(2) - foothold_xy.unsqueeze(1)
+    dist = torch.linalg.vector_norm(diff, dim=-1)                            # (E, F, S)
+    dist = torch.where(env._foothold_active.unsqueeze(1), dist, torch.full_like(dist, float("inf")))
+    min_dist, _ = dist.min(dim=-1)                                           # (E, F)
+
+    # Smooth penalty: 0 inside tolerance, linear ramp outside
+    excess = (min_dist - tolerance).clamp(min=0.0)                           # (E, F)
+    excess = excess * just_landed.float()                                    # gate by event
+    return -excess.sum(dim=-1)  # (E,)
+
+
+def claim_advance(env: "ManagerBasedRLEnv") -> torch.Tensor:
+    """Bonus when total claimed-foothold count increases this step.
+
+    Provides ordering-pressure on top of `foothold_landing` so the policy
+    advances through the chain rather than camping near a single stone.
+    """
+    cur = env._foothold_claimed.sum(dim=-1).long()                          # (E,)
+    delta = (cur - env._foothold_claim_count_prev).clamp(min=0).float()
+    env._foothold_claim_count_prev = cur
+    return delta
+
+
+# ----------------------------------------------------------------------------
+# Foot-on-slope penalty (Stage-2.5: trapezoidal/pyramid foot-placement signal)
+# ----------------------------------------------------------------------------
+
+def feet_on_slope_penalty(
+    env: "ManagerBasedRLEnv",
+    sensor_cfg: SceneEntityCfg,
+    contact_threshold: float = 5.0,
+    cos_slope_threshold: float = 0.95,
+) -> torch.Tensor:
+    """Penalty when a foot is in contact at a position where the SURFACE
+    NORMAL (inferred from the contact-force direction) deviates from world
+    vertical by more than the threshold.
+
+    The contact force in static contact is approximately along the surface
+    normal. So `force_z / |force|` ≈ cos(slope_angle). Below
+    `cos_slope_threshold` (default 0.95 ≈ 18.2°) the foot is "on a slope"
+    and we penalize it.
+
+    Privileged-at-train: uses contact sensor data (which the policy obs does
+    NOT see). Reward-shaping only — does not change deploy obs.
+
+    Returns: -count_of_feet_on_slope per env (E,).
+    """
+    sensor: ContactSensor = env.scene.sensors[sensor_cfg.name]
+    forces = sensor.data.net_forces_w[:, sensor_cfg.body_ids, :]   # (E, F, 3)
+    force_mag = torch.linalg.vector_norm(forces, dim=-1)            # (E, F)
+    in_contact = force_mag > contact_threshold                      # (E, F)
+    # cos(angle from vertical) = vertical component / magnitude
+    cos_angle = forces[..., 2] / force_mag.clamp(min=1e-6)          # (E, F)
+    on_slope = cos_angle < cos_slope_threshold                      # (E, F)
+    bad = in_contact & on_slope
+    # Return POSITIVE count of feet on slope. RewTerm weight should be
+    # NEGATIVE (e.g. -1.0) for this to act as a penalty — Isaac Lab
+    # convention is "func returns magnitude, weight carries the sign".
+    return bad.float().sum(dim=-1)
+
+
+# ----------------------------------------------------------------------------
+# Forward progress (linear) — counters the "don't move = no penalty" trap
+# ----------------------------------------------------------------------------
+
+def forward_progress(
+    env: "ManagerBasedRLEnv",
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    command_name: str = "base_velocity",
+) -> torch.Tensor:
+    """Linear reward: actual base xy velocity component along the COMMANDED
+    direction. Standing still → 0. Walking at commanded speed → magnitude
+    equal to commanded speed.
+
+    Why this is needed: track_lin_vel_xy_exp = exp(-error²/std²) collapses
+    to ~0 when error >> std, providing no gradient pulling the policy out of
+    a "stand still and the error is the full commanded speed" local minimum.
+    Linear progress reward keeps a constant gradient toward "go faster".
+
+    NOT a replacement for `track_lin_vel_xy_exp` — they're complementary.
+    Linear reward gives directional gradient; exp reward shapes precision.
+    """
+    asset = env.scene[asset_cfg.name]
+    cmd = env.command_manager.get_command(command_name)[:, :2]   # (E, 2) — lin_vel cmd in body frame
+    cmd_norm = torch.linalg.norm(cmd, dim=-1)                     # (E,)
+    eps = 1e-3
+    # If commanded velocity is essentially zero, the dot product is ill-defined;
+    # return 0 so this term doesn't reward random motion when commanded to stop.
+    valid = cmd_norm > eps
+    cmd_dir = cmd / cmd_norm.unsqueeze(-1).clamp(min=eps)         # unit dir (E, 2)
+    actual_vel_b = asset.data.root_lin_vel_b[:, :2]               # body-frame xy vel
+    progress = (actual_vel_b * cmd_dir).sum(dim=-1)               # (E,)
+    return progress * valid.float()
+
+
+# ----------------------------------------------------------------------------
+# Extreme Parkour reward design (Cheng 2024, arXiv 2309.14341 §4)
+# ----------------------------------------------------------------------------
+
+def forward_progress_world(
+    env: "ManagerBasedRLEnv",
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    command_name: str = "base_velocity",
+) -> torch.Tensor:
+    """Extreme Parkour forward-progress reward, CLIPPED and in WORLD frame.
+
+    r = clip( v_world · cmd_dir_world , 0 , |v_cmd| )
+
+    Differences from the (broken) v1 `forward_progress`:
+    1. World frame, not body frame. Prevents the policy from turning around
+       obstacles to maximise body-frame velocity along command (a known
+       failure mode noted in EP §4 — they explicitly call this out).
+    2. Clipped to [0, |v_cmd|]. Standing still: 0. Walking at commanded
+       speed along commanded direction: |v_cmd|. Walking faster than
+       commanded: same reward as walking at command speed (no over-speeding
+       bonus). Walking backwards or sideways: 0 (clipped at 0).
+    3. Bounded → no dive-forward attractor.
+
+    The cmd in `base_velocity` is in body frame; this function rotates it to
+    world frame using the base yaw to compare with v_world.
+    """
+    asset = env.scene[asset_cfg.name]
+    cmd_b = env.command_manager.get_command(command_name)[:, :2]     # (E, 2) body-frame
+    cmd_norm = torch.linalg.norm(cmd_b, dim=-1)                       # (E,)
+    eps = 1e-3
+    valid = cmd_norm > eps
+
+    # Compute base yaw from root quaternion (wxyz)
+    quat = asset.data.root_quat_w                                     # (E, 4)
+    siny_cosp = 2.0 * (quat[:, 0] * quat[:, 3] + quat[:, 1] * quat[:, 2])
+    cosy_cosp = 1.0 - 2.0 * (quat[:, 2] * quat[:, 2] + quat[:, 3] * quat[:, 3])
+    yaw = torch.atan2(siny_cosp, cosy_cosp)                           # (E,)
+    cy = torch.cos(yaw)
+    sy = torch.sin(yaw)
+
+    # Rotate cmd to world frame
+    cmd_world_x = cmd_b[:, 0] * cy - cmd_b[:, 1] * sy
+    cmd_world_y = cmd_b[:, 0] * sy + cmd_b[:, 1] * cy
+    cmd_world = torch.stack([cmd_world_x, cmd_world_y], dim=-1)       # (E, 2)
+    cmd_dir = cmd_world / cmd_norm.clamp(min=eps).unsqueeze(-1)        # unit dir (E, 2)
+
+    # Projected velocity along commanded direction (world frame)
+    v_world = asset.data.root_lin_vel_w[:, :2]                         # (E, 2)
+    progress = (v_world * cmd_dir).sum(dim=-1)                         # (E,)
+
+    # Clip to [0, |v_cmd|]: don't reward over-speeding or wrong-direction
+    progress = progress.clamp(min=0.0)
+    progress = torch.minimum(progress, cmd_norm)
+    return progress * valid.float()
+
+
+def stall_penalty(
+    env: "ManagerBasedRLEnv",
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    command_name: str = "base_velocity",
+    vel_threshold: float = 0.1,
+    cmd_threshold: float = 0.3,
+) -> torch.Tensor:
+    """Penalty (positive output, NEGATIVE weight in cfg) when the robot is
+    nearly stationary while being commanded to move.
+
+    Fires when |v_world_xy| < `vel_threshold` AND |cmd_xy| > `cmd_threshold`.
+
+    Counters the "stand still / shuffle in place" attractor on hard terrain
+    that the bounded velocity-tracking reward alone cannot escape.
+    """
+    asset = env.scene[asset_cfg.name]
+    v_speed = torch.linalg.norm(asset.data.root_lin_vel_w[:, :2], dim=-1)
+    cmd = env.command_manager.get_command(command_name)[:, :2]
+    cmd_speed = torch.linalg.norm(cmd, dim=-1)
+    stalling = (v_speed < vel_threshold) & (cmd_speed > cmd_threshold)
+    return stalling.float()

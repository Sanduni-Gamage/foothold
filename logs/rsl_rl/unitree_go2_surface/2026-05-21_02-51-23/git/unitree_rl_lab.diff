+def lidar_distances(
+    env: ManagerBasedRLEnv,
+    sensor_cfg: SceneEntityCfg,
+    max_range: float = 30.0,
+    min_range: float = 0.05,
+    noise_std: float = 0.02,
+    dropout_prob: float = 0.10,
+    log_scale: bool = True,
+) -> torch.Tensor:
+    """Per-ray distances from a RayCaster lidar, with realism augmentations.
+
+    Models the Unitree L1 4D LiDAR sensor characteristics from the L1 v1.1 user
+    manual:
+      - measurement accuracy ±2.0 cm  → Gaussian noise with std `noise_std`
+      - reflectance-dependent dropouts → per-ray Bernoulli dropout, dropped rays
+        clamped to `max_range` (modeling "no return → max")
+      - 0.05 m near blind zone, 30 m max  → clip output to (min_range, max_range)
+
+    Returns a (num_envs, num_rays) tensor of distances. With ``log_scale=True``
+    the output is ``log1p(distance)`` to compress the dynamic range for the
+    policy MLP. The privileged critic obs should call this with ``noise_std=0,
+    dropout_prob=0`` for clean ground-truth distances.
+    """
+    sensor: RayCaster = env.scene.sensors[sensor_cfg.name]
+    # ray_hits_w: (E, R, 3) world-frame hit points; pos_w: (E, 3) sensor pos
+    sensor_pos = sensor.data.pos_w.unsqueeze(1)            # (E, 1, 3)
+    distances = torch.linalg.vector_norm(sensor.data.ray_hits_w - sensor_pos, dim=-1)  # (E, R)
+
+    # rays that didn't hit anything return inf or huge values; treat as max_range
+    distances = torch.where(torch.isfinite(distances), distances, torch.full_like(distances, max_range))
+
+    if noise_std > 0.0:
+        distances = distances + noise_std * torch.randn_like(distances)
+    if dropout_prob > 0.0:
+        keep = torch.bernoulli(torch.full_like(distances, 1.0 - dropout_prob)).bool()
+        distances = torch.where(keep, distances, torch.full_like(distances, max_range))
+
+    distances = distances.clamp(min=min_range, max=max_range)
+
+    if log_scale:
+        distances = torch.log1p(distances)
+    return distances
+
+
+def nearest_unclaimed_footholds(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    k: int = 4,
+) -> torch.Tensor:
+    """K nearest unclaimed footholds, expressed in robot xy frame, sorted by
+    distance from base. Returns shape (E, k*2). Permutation-invariant in foot
+    index — provides the robot with a SET view of available footholds.
+
+    For envs with fewer than `k` unclaimed footholds, missing slots are
+    filled with the SAME max-range placeholder so the policy can detect them.
+    """
+    _ensure_state(env)
+    asset = env.scene[asset_cfg.name]
+    base_pos_w = asset.data.root_pos_w[:, :2]                           # (E, 2)
+    base_quat_w = asset.data.root_quat_w                                # (E, 4)
+
+    foothold_xy = env._foothold_positions                                # (E, S, 2)
+    invalid = env._foothold_claimed | (~env._foothold_active)             # (E, S)
+
+    # Distance from base in world frame
+    rel_xy = foothold_xy - base_pos_w.unsqueeze(1)                        # (E, S, 2)
+    dist = torch.linalg.vector_norm(rel_xy, dim=-1)                       # (E, S)
+    dist = torch.where(invalid, torch.full_like(dist, 1e6), dist)
+
+    # k-nearest by distance
+    k_actual = min(k, dist.shape[1])
+    _, top_idx = dist.topk(k_actual, dim=-1, largest=False)                # (E, k)
+    e_idx = torch.arange(env.num_envs, device=env.device).unsqueeze(1).expand(-1, k_actual)
+    nearest_xy = rel_xy[e_idx, top_idx]                                    # (E, k, 2) world-frame relative
+
+    # Transform to robot frame: rotate by inverse(base_quat). For 2-D xy we
+    # promote to 3-D, rotate, take xy back.
+    nearest_xy3 = torch.cat([nearest_xy, torch.zeros_like(nearest_xy[..., :1])], dim=-1)  # (E, k, 3)
+    nearest_rf = torch.zeros_like(nearest_xy3)
+    for i in range(k_actual):
+        nearest_rf[:, i, :] = quat_apply_inverse(base_quat_w, nearest_xy3[:, i, :])
+
+    # Cap at MAX_RANGE — invalid slots get clamped so they don't dominate
+    out_xy = nearest_rf[..., :2].clamp(min=-15.0, max=15.0)                # (E, k, 2)
+
+    return out_xy.reshape(env.num_envs, -1)                                # (E, k*2)
+
+
+def foot_positions_robot_frame(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg,
+) -> torch.Tensor:
+    """Foot xyz positions in robot frame, flattened to (E, 4*3=12).
+
+    asset_cfg.body_ids must be the four foot body indices.
+    """
+    asset = env.scene[asset_cfg.name]
+    foot_pos_w = asset.data.body_pos_w[:, asset_cfg.body_ids, :]           # (E, 4, 3)
+    base_pos_w = asset.data.root_pos_w.unsqueeze(1)                        # (E, 1, 3)
+    base_quat_w = asset.data.root_quat_w                                   # (E, 4)
+    rel = foot_pos_w - base_pos_w                                          # (E, 4, 3)
+    out = torch.zeros_like(rel)
+    for i in range(rel.shape[1]):
+        out[:, i, :] = quat_apply_inverse(base_quat_w, rel[:, i, :])
+    return out.reshape(env.num_envs, -1)
